{
  "permissions": {
    "allow": [
      "Bash(uv sync:*)",
      "Bash(uv run pytest:*)",
      "Read",
      "Write",
      "Edit",
      "TaskList",
      "TaskUpdate",
      "WebFetch",
      "WebSearch",
      "Bash(mkdir -p:*)",
      "Bash(git:*)",
      "Bash(rm .git/index)",
      "Bash(bash .claude/skills/deliberate-consensus/scripts/timestamp.sh)",
      "Bash(bash .claude/skills/deliberate-consensus/scripts/validate-artifact.sh *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(~/.aws/**)",
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(unlink:*)",
      "Bash(rmdir:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(chgrp:*)",
      "Bash(del:*)",
      "Bash(erase:*)",
      "Bash(rmdir /s:*)",
      "Bash(icacls:*)",
      "Bash(takeown:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/context-sentinel-session-start.sh"
          }
        ]
      }
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {
    "claude-mem@thedotmack": false,
    "superpowers@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true
  },
  "outputStyle": "Explanatory"
}
